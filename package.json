{
  "name": "fit-sihirbaz",
  "private": true,
  "version": "0.0.1",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @fit-sihirbaz/web dev",
    "dev:api": "pnpm --filter @fit-sihirbaz/api start:dev",
    "dev:mobile": "pnpm --filter @fit-sihirbaz/mobile start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @fit-sihirbaz/db generate",
    "db:migrate": "pnpm --filter @fit-sihirbaz/db migrate",
    "db:seed": "pnpm --filter @fit-sihirbaz/db seed"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
