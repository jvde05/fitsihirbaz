# Veritabanı
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fit_sihirbaz?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
