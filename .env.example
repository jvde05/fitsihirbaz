# Veritabanı
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fit_sihirbaz?schema=public

# Auth
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Redis / Job queue
REDIS_URL=redis://localhost:6379

# Dosya depolama (S3 uyumlu)
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Ödeme (ileriki faz)
IYZICO_API_KEY=
IYZICO_SECRET=

# Arama
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# Bildirim
EXPO_PUSH_TOKEN=
RESEND_API_KEY=

# apps/api
API_PORT=4000
WEB_ORIGIN=http://localhost:3000,http://localhost:8081

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:4000
