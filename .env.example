IYZICO_SECRET=
PAYMENT_WEBHOOK_SECRET=change-me-payment-webhook-secret

# Arama
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=

# Bildirim / E-posta (Resend). Boşsa e-postalar apps/api konsoluna loglanır (dev fallback).
EXPO_PUSH_TOKEN=
RESEND_API_KEY=
MAIL_FROM=Fit Sihirbaz <onboarding@resend.dev>

# apps/api
API_PORT=4000
WEB_ORIGIN=http://localhost:3000,http://localhost:8081
